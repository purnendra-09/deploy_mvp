# .env.example
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Production values go into Firebase Secret Manager.
# ─────────────────────────────────────────────────────────────

# ── Twilio (store in Secret Manager for production) ───────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── QR Token signing key (min 32 chars, random) ───────────────
QR_HMAC_SECRET=replace_with_a_long_random_secret_key_here

# ── Firebase project ──────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# ── App settings (can also live in Firestore settings/config) ─
SCHOOL_TIMEZONE=Asia/Kolkata
MORNING_CUTOFF_HOUR=12
ABSENT_CHECK_CRON=5 10 * * 1-5
